MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=insightai

# Used to sign JWTs. Set a long random string in production.
SECRET_KEY=change_this_to_a_long_random_string

# From https://console.cloud.google.com/apis/credentials
# Create an OAuth 2.0 Client ID (Web application), add your frontend origin
# (e.g. http://localhost:5173) under "Authorized JavaScript origins", and
# paste the Client ID here. Required for "Continue with Google" to work.
GOOGLE_CLIENT_ID=
