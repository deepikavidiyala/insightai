# Base URL of the InsightAI FastAPI backend (no trailing slash)
VITE_API_BASE_URL=http://localhost:8000

# From https://console.cloud.google.com/apis/credentials — an OAuth 2.0
# Web application Client ID with this app's origin allowed. Leave blank to
# hide/disable the "Continue with Google" button.
VITE_GOOGLE_CLIENT_ID=
